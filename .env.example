# Frontend Environment Variables
# API URL - Backend API endpoint (REQUIRED)
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Chance purchase contract (mainnet)
NEXT_PUBLIC_CHANCE_CONTRACT_ADDRESS=
NEXT_PUBLIC_PLAN_GO_PRICE_WEI=100000000000000
NEXT_PUBLIC_PLAN_PRO_PRICE_WEI=200000000000000
NEXT_PUBLIC_PLAN_MAX_PRICE_WEI=300000000000000

# ── Testnet Faucet (server-side only — never expose to client) ──────────────
# EVM private key of the hot wallet that holds faucet funds.
# Format: 0x-prefixed 32-byte hex, e.g. 0xabcd1234...
FAUCET_PRIVATE_KEY=

# EVM address of that same wallet (used to query balances publicly).
# This IS safe to expose; it is the wallet's public address.
FAUCET_WALLET_ADDRESS=
