# ─────────────────────────────────────────────────────────────
# INJ Pass Frontend Environment
# ─────────────────────────────────────────────────────────────

# Backend endpoint (choose one; NEXT_PUBLIC_BACKEND_URL preferred)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Network
NEXT_PUBLIC_NETWORK=mainnet

# Allowed auth-bridge origins (comma-separated)
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Chance purchase contract and pricing
NEXT_PUBLIC_CHANCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PLAN_GO_PRICE_WEI=33000000000000000
NEXT_PUBLIC_PLAN_PRO_PRICE_WEI=108000000000000000
NEXT_PUBLIC_PLAN_MAX_PRICE_WEI=330000000000000000

# Faucet (server-side routes only)
FAUCET_PRIVATE_KEY=
FAUCET_WALLET_ADDRESS=

# Virtual Eric support chat (server-side route only)
SUPPORT_AI_API_KEY=
SUPPORT_AI_BASE_URL=https://yinli.one/v1
SUPPORT_AI_MODEL=deepseek-v3.2
