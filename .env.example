# ─────────────────────────────────────────────────────────────
# INJ Pass Frontend Environment
# ─────────────────────────────────────────────────────────────

# Backend endpoint (choose one; NEXT_PUBLIC_BACKEND_URL preferred)
# NEXT_PUBLIC_BACKEND_URL is normalized to `${url}/api` by the frontend.
NEXT_PUBLIC_BACKEND_URL=https://your-backend.example.com
NEXT_PUBLIC_API_URL=https://your-backend.example.com/api

# Network
# Must match the deployed ChanceManager and CatNFT addresses below.
# Use `mainnet` for Injective EVM mainnet or `testnet` for Injective EVM testnet.
NEXT_PUBLIC_NETWORK=mainnet

# Allowed auth-bridge origins (comma-separated)
NEXT_PUBLIC_ALLOWED_ORIGINS=https://your-frontend.example.com

# Chance purchase contract and pricing
# This address is read together with NEXT_PUBLIC_NETWORK.
# mainnet env must use the mainnet ChanceManager; testnet env must use the testnet ChanceManager.
NEXT_PUBLIC_CHANCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PLAN_GO_PRICE_WEI=33000000000000000
NEXT_PUBLIC_PLAN_PRO_PRICE_WEI=108000000000000000
NEXT_PUBLIC_PLAN_MAX_PRICE_WEI=330000000000000000

# CatNFT contract (set after deployment)
# This address must be on the same chain as NEXT_PUBLIC_NETWORK.
NEXT_PUBLIC_CATNFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Faucet (server-side routes only)
# Optional. Leave empty if the frontend faucet routes are not used in production.
FAUCET_PRIVATE_KEY=
FAUCET_WALLET_ADDRESS=

# Virtual Eric support chat (server-side route only)
SUPPORT_AI_API_KEY=
SUPPORT_AI_BASE_URL=https://yinli.one/v1
SUPPORT_AI_MODEL=deepseek-v3.2

# Collection uploads are handled by the backend via Pinata.
# No Pinata key is required in the frontend.
